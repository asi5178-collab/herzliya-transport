# מפתח API של Anthropic - חובה לניתוח WhatsApp
ANTHROPIC_API_KEY=your-api-key-here

# הגדרות שרת
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# מפתח JWT - שנה למחרוזת סודית ארוכה!
JWT_SECRET=herzliya-transport-secret-change-this-2026

# נתיב בסיס נתונים
DB_PATH=./database/herzliya.db

# הגדרות כלליות
CITY_NAME=הרצליה
SYSTEM_NAME=מערכת הסעות תיכונים - הרצליה
